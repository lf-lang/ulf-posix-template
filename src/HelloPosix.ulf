@platform("posix")
@timeout(10 sec)
main reactor {
  timer t1(0, 1 sec)

  reaction(t1) {=
    interval_t logical_time = env->get_elapsed_logical_time(env);
    interval_t physical_time = env->get_elapsed_physical_time(env);
    printf("Hello World @ lt=%lld, pt=%lld, lag=%lld\n", logical_time, physical_time, physical_time - logical_time);
  =}
}
